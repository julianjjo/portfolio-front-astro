---
import Skill from "@components/Skill.astro";
import Layout from "@layouts/Layout.astro";

const backendSkills = [
    { nameIcon: "JavaIcon", label: "Java", percentage: "98" },
    { nameIcon: "PhpIcon", label: "PHP", percentage: "99" },
    { nameIcon: "PythonIcon", label: "Python", percentage: "98" },
    { nameIcon: "NodeJsIcon", label: "Node.js", percentage: "90" },
    { nameIcon: "SpringBootIcon", label: "Spring Boot", percentage: "95" },
    { nameIcon: "NestJsIcon", label: "NestJS", percentage: "95" },
    { nameIcon: "SymfonyIcon", label: "Symfony", percentage: "90" },
];

const otherSkills = [
    { nameIcon: "TsIcon", label: "TypeScript", percentage: "90" },
    { nameIcon: "CssIcon", label: "CSS", percentage: "95" },
    { nameIcon: "HtmlIcon", label: "HTML", percentage: "95" },
    { nameIcon: "MySqlIcon", label: "MySQL", percentage: "98" },
    { nameIcon: "PostgreSqlIcon", label: "PostgreSQL", percentage: "98" },
    { nameIcon: "AwsIcon", label: "AWS", percentage: "90" },
    { nameIcon: "GoogleCloudIcon", label: "Google Cloud", percentage: "90" },
];
---

<Layout
    title="Technical Expertise | Julian Mican"
    description="Extensive experience in Java, PHP, Python, and modern cloud architectures."
>
    <div class="relative pt-32 pb-20 px-4 md:px-20 max-w-7xl mx-auto">
        <!-- Header -->
        <div class="text-center mb-16 animate-slide-up">
            <p class="eyebrow mb-5">Skills</p>
            <h1
                class="text-5xl md:text-7xl font-black playfair-display mb-6 bg-clip-text text-transparent bg-gradient-to-r from-slate-100 to-slate-400"
            >
                Skills & Expertise
            </h1>
            <div
                class="h-px w-24 accent-gradient mx-auto rounded-full mb-6"
                style="box-shadow: 0 0 15px var(--accent-soft);"
            >
            </div>
            <p class="text-slate-400 max-w-2xl mx-auto text-lg">
                A comprehensive toolkit built over 8 years of professional
                development, focusing on backend scalability and cloud
                excellence.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
            <!-- Backend Section -->
            <section
                class="space-y-6 animate-slide-up"
                style="animation-delay: 200ms"
            >
                <div class="flex items-center gap-4 mb-8">
                    <div
                        class="h-px flex-grow bg-gradient-to-r from-transparent to-white/10"
                    >
                    </div>
                    <h2 class="eyebrow">
                        Main Stack
                    </h2>
                    <div
                        class="h-px flex-grow bg-gradient-to-l from-transparent to-white/10"
                    >
                    </div>
                </div>
                <div class="grid grid-cols-1 gap-4">
                    {
                        backendSkills.map((skill) => (
                            <Skill
                                widthIcon="40"
                                heightIcon="40"
                                nameIcon={skill.nameIcon}
                                label={skill.label}
                                percentage={skill.percentage}
                            />
                        ))
                    }
                </div>
            </section>

            <!-- Others Section -->
            <section
                class="space-y-6 animate-slide-up"
                style="animation-delay: 400ms"
            >
                <div class="flex items-center gap-4 mb-8">
                    <div
                        class="h-px flex-grow bg-gradient-to-r from-transparent to-white/10"
                    >
                    </div>
                    <h2 class="eyebrow eyebrow-alt">
                        Tools & Cloud
                    </h2>
                    <div
                        class="h-px flex-grow bg-gradient-to-l from-transparent to-white/10"
                    >
                    </div>
                </div>
                <div class="grid grid-cols-1 gap-4">
                    {
                        otherSkills.map((skill) => (
                            <Skill
                                widthIcon="40"
                                heightIcon="40"
                                nameIcon={skill.nameIcon}
                                label={skill.label}
                                percentage={skill.percentage}
                            />
                        ))
                    }
                </div>
            </section>
        </div>
    </div>
</Layout>

<style>
    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(40px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .animate-slide-up {
        animation: slideUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) both;
    }
</style>
