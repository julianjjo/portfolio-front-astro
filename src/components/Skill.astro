---
import Icons from "@icons/Icons.astro";

interface Props {
  widthIcon: string;
  heightIcon: string;
  nameIcon: string;
  label?: string;
  percentage: string;
}

const { nameIcon, widthIcon, heightIcon, label, percentage } = Astro.props;
const displayName = label ?? nameIcon.replace("Icon", "");
---

<div
  class="group flex flex-col gap-4 p-6 glass-card rounded-2xl hover:border-[color:var(--accent-soft)] transition-all duration-300"
>
  <div class="flex items-center gap-4">
    <div
      class="flex-shrink-0 p-3 bg-white/5 rounded-xl group-hover:bg-white/10 transition-colors border border-white/5"
    >
      <Icons width={widthIcon} height={heightIcon} name={nameIcon} />
    </div>
    <div class="flex-grow">
      <div class="flex justify-between items-end mb-2">
        <span
          class="text-sm font-bold text-slate-300 group-hover:text-white transition-colors tracking-wide uppercase"
        >
          {displayName}
        </span>
        <span class="text-xs plex-mono accent-text font-semibold"
          >{percentage}%</span
        >
      </div>
      <div
        class="w-full bg-white/5 rounded-full h-1.5 overflow-hidden border border-white/5"
      >
        <div
          class="skill-bar h-full rounded-full accent-gradient"
          style={`width: ${percentage}%; box-shadow: 0 0 10px var(--accent-soft);`}
        >
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .skill-bar {
    animation: fillBar 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) 0.3s both;
  }

  @keyframes fillBar {
    from {
      width: 0;
    }
  }
</style>
