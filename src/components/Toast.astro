---
interface Props {
  type: string;
  className: string;
}

const { type, className } = Astro.props;

const variants: Record<
  string,
  { id: string; message: string; iconClass: string; path: string }
> = {
  Success: {
    id: "toast-success",
    message: "Message sent. I'll get back to you within a day.",
    iconClass: "text-emerald-400 bg-emerald-400/10",
    path: "M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5Zm3.707 8.207-4 4a1 1 0 0 1-1.414 0l-2-2a1 1 0 0 1 1.414-1.414L9 10.586l3.293-3.293a1 1 0 0 1 1.414 1.414Z",
  },
  Danger: {
    id: "toast-danger",
    message: "Your message didn't go through. Please try again.",
    iconClass: "text-red-400 bg-red-400/10",
    path: "M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5Zm3.707 11.793a1 1 0 1 1-1.414 1.414L10 11.414l-2.293 2.293a1 1 0 0 1-1.414-1.414L8.586 10 6.293 7.707a1 1 0 0 1 1.414-1.414L10 8.586l2.293-2.293a1 1 0 0 1 1.414 1.414L11.414 10l2.293 2.293Z",
  },
  Warning: {
    id: "toast-warning",
    message: "Check the highlighted fields and try again.",
    iconClass: "text-amber-400 bg-amber-400/10",
    path: "M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM10 15a1 1 0 1 1 0-2 1 1 0 0 1 0 2Zm1-4a1 1 0 0 1-2 0V6a1 1 0 0 1 2 0v5Z",
  },
};

const variant = variants[type];
---

{
  variant && (
    <div
      id={variant.id}
      class={
        "glass-card flex items-center w-full max-w-xs p-4 mb-4 rounded-2xl text-slate-200 " +
        className
      }
      role="alert"
    >
      <div
        class={
          "inline-flex items-center justify-center flex-shrink-0 w-8 h-8 rounded-xl " +
          variant.iconClass
        }
      >
        <svg
          class="w-5 h-5"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path d={variant.path} />
        </svg>
      </div>
      <div class="ms-3 text-sm font-normal">{variant.message}</div>
      <button
        type="button"
        onclick={`document.getElementById('${variant.id}').classList.add('disappear');`}
        class="ms-auto -mx-1.5 -my-1.5 p-1.5 inline-flex items-center justify-center h-8 w-8 rounded-xl text-slate-500 hover:text-white hover:bg-white/10 transition-colors"
        aria-label="Close"
      >
        <span class="sr-only">Close</span>
        <svg
          class="w-3 h-3"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 14 14"
        >
          <path
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"
          />
        </svg>
      </button>
    </div>
  )
}

<style>
  @keyframes disappearAnimation {
    0% {
      opacity: 1;
      transform: rotateX(90deg);
    }
    50% {
      opacity: 0.5;
      transform: rotateX(0deg);
    }
    100% {
      display: none;
      opacity: 0;
      transform: rotateX(90deg);
    }
  }

  .disappear {
    animation-name: disappearAnimation;
    animation-duration: 2000ms;
    animation-fill-mode: forwards;
  }
</style>
